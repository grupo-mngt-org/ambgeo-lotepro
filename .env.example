# Lote Pro — exemplo de configuração (copie para .env e ajuste)

# Autenticação (RNF03)
LOTEPRO_USER=admin
LOTEPRO_PASSWORD=lotepro
LOTEPRO_SECRET=troque-por-uma-chave-aleatoria-em-producao
LOTEPRO_TOKEN_TTL=28800

# Persistência (filesystem)
LOTEPRO_DATA_DIR=./data

# Banco de dados (Postgres via docker compose). Postgres sobe VAZIO na Fase 1
# — a app ainda persiste em arquivo; estas vars ficam prontas para a Fase 2.
POSTGRES_DB=lotepro
POSTGRES_USER=lotepro
POSTGRES_PASSWORD=troque-esta-senha
# Usada pela app dentro do compose (host 'db'). Para rodar a app fora do
# compose contra o Postgres local, troque 'db' por 'localhost:5436'.
DATABASE_URL=postgresql://lotepro:troque-esta-senha@db:5432/lotepro

# DataJud (CNJ) — chave PÚBLICA documentada pelo CNJ (igual para todos).
# Já tem default no código; descomente só para sobrescrever.
# DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# Google Earth Engine (opcional — provider 'gee')
# GEE_SERVICE_ACCOUNT=conta@projeto.iam.gserviceaccount.com
# GEE_KEY_FILE=./gee-key.json

# Motor de Bolhas (IA) — OpenRouter. Sem chave, o estudo roda em modo
# determinístico (ranking por regras). Os modelos são tentados em ordem
# (fallback): se o 1º falhar/instável, cai para o 2º e o 3º.
# open_router_key=sk-or-v1-...
# open_router_model=modelo/principal:free
# open_router_model2=modelo/reserva:free
# open_router_model3=modelo/reserva2:free
# OPENROUTER_TIMEOUT=180   # timeout de socket por leitura (modelos free são lentos)
# OPENROUTER_DEADLINE=300  # prazo total da corrida entre modelos (→ heurístico se estourar)
# Dica: em produção, aponte open_router_model para um modelo RÁPIDO (paga) e a
# análise sai em segundos; os :free são lentos (45–270 s) e variáveis.
