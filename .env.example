# Lote Pro — exemplo de configuração (copie para .env e ajuste)

# Autenticação (RNF03)
LOTEPRO_USER=admin
LOTEPRO_PASSWORD=lotepro
LOTEPRO_SECRET=troque-por-uma-chave-aleatoria-em-producao
LOTEPRO_TOKEN_TTL=28800

# Persistência
LOTEPRO_DATA_DIR=./data

# Google Earth Engine (opcional — provider 'gee')
# GEE_SERVICE_ACCOUNT=conta@projeto.iam.gserviceaccount.com
# GEE_KEY_FILE=./gee-key.json
